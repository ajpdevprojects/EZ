# Supabase (required for auth + persisted data; without these the app runs
# in local demo mode with in-memory sample data).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI providers (optional — Ask EZ works only when at least one is set).
# Checked in this order: Anthropic, OpenAI, Google.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_MODEL=gemini-2.5-pro

# Background jobs (optional — job discovery ingestion and interview
# reminders are disabled until both are set). SUPABASE_SERVICE_ROLE_KEY
# comes from the Supabase project's API settings and must never be
# exposed to the browser. CRON_SECRET is any random string you generate;
# Vercel automatically sends it as a bearer token when it invokes the
# scheduled routes in vercel.json, so cron endpoints reject everyone else.
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=
